# ============================================================
# .env.example — Copia como .env y ajusta los valores
# NUNCA subas .env real a git
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=eon_index_clima
POSTGRES_USER=eon
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
POSTGRES_PORT=5435

# URL completa para SQLAlchemy (se construye automáticamente desde los campos anteriores,
# pero puedes sobreescribirla aquí si usas un servidor externo)
# DATABASE_URL=postgresql://eon:password@localhost:5435/eon_index_clima

# ── API ──────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# ── Rutas ────────────────────────────────────────────────────
DATA_DIR=data
QUOTES_DIR=data/quotes
REPORTS_DIR=data/reports
OBSIDIAN_VAULT=D:\INDEX_CLIMA_CONOCIMIENTO_IA
